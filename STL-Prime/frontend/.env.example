# ==========================================
# 🛠️ STL Prime - Environment Variables
# ==========================================

# 1. Supabase (Database, Auth, Storage)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-project-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# 2. Base URL (Utilizado para redirecionamentos e e-mails)
NEXT_PUBLIC_BASE_URL="http://localhost:3000" # Mude para seu domínio na Vercel em produção

# 3. Stripe (Pagamentos e Assinaturas)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# 4. Resend (Servidor Transacional de E-mails)
RESEND_API_KEY="re_..."
NEXT_PUBLIC_RESEND_FROM_EMAIL="Ola <onboarding@resend.dev>" # Use onboarding@resend.dev para testes
